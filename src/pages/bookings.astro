---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
  title="Book an Appointment"
  description="Schedule an appointment with A1 Quality Paralegal in Grants Pass, Oregon."
>
  <section class="page-hero reveal">
    <div class="page-hero__inner">
      <h1>Book an Appointment</h1>
      <p>Choose a time that works for you. We will confirm your appointment and prepare for your visit.</p>
    </div>
  </section>

  <section class="booking reveal delay-1">
    <div class="booking__inner">
      <div class="booking__info">
        <h2>How It Works</h2>
        <ul>
          <li>Choose a service type and preferred time below.</li>
          <li>We confirm your appointment and any required documents.</li>
          <li>Meet in person or by phone for your consultation.</li>
        </ul>
        <p style="margin-top: 24px;"><strong>Prefer to call?</strong></p>
        <p><a href="tel:+15414742260">541-474-2260</a></p>
        <p><a href="mailto:a1qualitydocuments@gmail.com">a1qualitydocuments@gmail.com</a></p>
        <p style="margin-top: 24px;">Not sure what you need? <a href={`${base}contact-us/`}>Send us a message</a> and we will help you figure it out.</p>
      </div>
      <div class="booking__form">
        <h3>Request a Time</h3>
        <p>Use the calendar below to schedule your appointment.</p>
        <div class="booking__embed">
          <iframe
            src="https://calendar.google.com/calendar/appointments/AcZssZ0yhqmSu5PLaG2up8ZsB_KFKc-AS1YFYnLpmUs?gv=true"
            style="border: 0"
            width="100%"
            height="600"
            frameborder="0"
            title="A1 Quality Paralegal Appointment Scheduling"
            loading="lazy"
          ></iframe>
          <p>
            Calendar not loading?
            <a
              href="https://calendar.google.com/calendar/appointments/AcZssZ0yhqmSu5PLaG2up8ZsB_KFKc-AS1YFYnLpmUs?gv=true"
              target="_blank"
              rel="noopener noreferrer"
            >Open it directly</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
